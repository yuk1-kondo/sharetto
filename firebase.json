{
  "hosting": {
    "site": "sharetto",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/manifest.webmanifest",
        "headers": [{ "key": "Content-Type", "value": "application/manifest+json" }]
      }
    ],
    "rewrites": [
      { "source": "/join.html", "destination": "/join.html" },
      { "source": "/upload.html", "destination": "/upload.html" },
      { "source": "/upload-liquid-glass.html", "destination": "/upload-liquid-glass.html" },
      { "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  },
  "functions": {
    "source": "functions"
  },
  "emulators": {
    "hosting": { "port": 5000 },
    "database": { "port": 9000 },
    "functions": { "port": 5001 },
    "ui": { "enabled": true }
  }
}
